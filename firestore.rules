rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default safety deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Collection: Users
    match /users/{userId} {
      allow read: if true;
      // Allow create/update only if the user is signed in and owns their record
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // Collection: Issues
    match /issues/{issueId} {
      allow read, list: if true;
      // Allow create if signed in and reportedBy matches current user UID
      allow create: if isSignedIn() && request.resource.data.reportedBy == request.auth.uid;
      
      // Allow update if signed in, but non-owners can only upvote or perform warden resolution state updates
      allow update: if isSignedIn() && (
        // Case A: Reporter can update their own issue (must not change reportedBy)
        (resource.data.reportedBy == request.auth.uid && request.resource.data.reportedBy == resource.data.reportedBy) ||
        // Case B: Any signed-in user can upvote (affecting only 'upvotes' and 'updatedAt')
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'updatedAt']) ||
        // Case C: Warden actions - testing controls can update status, resolvedAt, resolvedImageUrl, verificationReason, and updatedAt
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'verificationReason', 'resolvedImageUrl', 'resolvedAt', 'updatedAt']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if false;
    }

    // Collection: Zone Predictions (written by background prediction tasks)
    match /zonePredictions/{predictionId} {
      allow read, list: if true;
      // Allow write only if signed in
      allow write: if isSignedIn();
    }

    // Collection: Notifications
    match /notifications/{notifId} {
      // Only allow a user to read their own notifications
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Anyone signed in can create a notification (e.g. upvote notifications)
      allow create: if isSignedIn();
      // Only the recipient user can update their own notification (e.g. marking as read)
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Collection: Activities (historical actions logged)
    match /activities/{activityId} {
      allow read: if true;
      // Seeding and client logging can create logs, but updates/deletes are blocked
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Collection: Analytics (Dashboard indexes, read-only to public)
    match /analytics/{docId} {
      allow read: if true;
      // server-only via Admin SDK
      allow write: if false;
    }

  }
}
